{
  "name": "bankers-algorithm-simulator",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:vanilla": "http-server public -p 5000",
    "serve": "npx http-server public -p 8000 --cors",
